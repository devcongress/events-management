# Public Supabase client values. Safe to expose in browser builds.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose this with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Optional route hardening for organizer pages.
VITE_ADMIN_BASE_PATH=/organizer-console
VITE_SHOW_ORGANIZER_LINK=true
VITE_SHOW_FEEDBACK_BOT=true

# Local admin fallback used only when Supabase admin auth is not configured.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
